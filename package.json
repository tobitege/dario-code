{
  "name": "openclaude",
  "version": "1.0.0",
  "bin": {
    "openclaude": "openclaude.mjs",
    "claude": "cli.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "author": "OpenClaude Contributors",
  "license": "MIT",
  "description": "Open Claude Code - An open source CLI for Claude. Use Claude AI right from your terminal with full codebase understanding.",
  "homepage": "https://github.com/jkneen/openclaude",
  "repository": {
    "type": "git",
    "url": "https://github.com/jkneen/openclaude.git"
  },
  "bugs": {
    "url": "https://github.com/jkneen/openclaude/issues"
  },
  "scripts": {
    "start": "./cli.mjs",
    "dev": "OPENCLAUDE_TUI=claude ./cli.mjs",
    "dev:minimal": "OPENCLAUDE_TUI=minimal ./cli.mjs",
    "dev:custom": "OPENCLAUDE_TUI=custom ./cli.mjs",
    "dev:readable": "OPENCLAUDE_USE_READABLE_TOOLS=1 OPENCLAUDE_TUI=claude ./cli.mjs",
    "dev:debug": "DEBUG=true OPENCLAUDE_USE_READABLE_TOOLS=1 OPENCLAUDE_TUI=claude ./cli.mjs",
    "tui:list": "echo 'Available TUIs:' && ls -1 src/tui/ | grep -v interface.mjs | grep -v loader.mjs",
    "test": "node tests/integration.test.mjs",
    "test:unit": "vitest run",
    "test:readable": "OPENCLAUDE_USE_READABLE_TOOLS=1 node tests/integration.test.mjs",
    "test:debug": "DEBUG=true OPENCLAUDE_USE_READABLE_TOOLS=1 node tests/integration.test.mjs",
    "test:all": "npm test && npm run test:unit"
  },
  "main": "src/index.mjs",
  "files": [
    "cli.mjs",
    "openclaude.mjs",
    "src/**/*",
    "docs/**/*"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@openauthjs/openauth": "^0.4.3",
    "@sentry/node": "^7.108.0",
    "chalk": "^5.3.0",
    "cli-boxes": "^3.0.0",
    "cli-spinners": "^2.9.2",
    "commander": "^14.0.2",
    "dotenv": "^16.3.1",
    "glob": "^10.3.10",
    "highlight.js": "^11.9.0",
    "ink": "^4.4.1",
    "ink-select-input": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "lodash": "^4.17.21",
    "marked": "^11.2.0",
    "marked-terminal": "^6.2.0",
    "node-fetch": "^3.3.2",
    "open": "^10.0.0",
    "parse5": "^7.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.3.4",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.1"
  },
  "optionalDependencies": {
    "@img/sharp-darwin-arm64": "^0.33.5",
    "@img/sharp-linux-arm": "^0.33.5",
    "@img/sharp-linux-x64": "^0.33.5",
    "@img/sharp-win32-x64": "^0.33.5"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
